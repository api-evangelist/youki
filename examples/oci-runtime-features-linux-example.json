      ],
      "archs": [
        "SCMP_ARCH_M68K",
        "SCMP_ARCH_SH"
      ],
      "knownFlags": [
        "SECCOMP_FILTER_FLAG_TSYNC",
        "SECCOMP_FILTER_FLAG_LOG"
      ],
      "supportedFlags": [
        "SECCOMP_FILTER_FLAG_SPEC_ALLOW",
        "SECCOMP_FILTER_FLAG_LOG"
      ]
    },
    "apparmor": {
      "enabled": false
    },
    "intelRdt": {
      "enabled": true
    },
    "mountExtensions": {
